# --- Telegram user account (get from https://my.telegram.org > API development) ---
API_ID=1234567
API_HASH=0123456789abcdef0123456789abcdef

# Session name (a .session file is created next to the script). Keep it private.
SESSION_NAME=yor_exporter

# Optional: log in with a StringSession instead of a file session.
# Generate once with:  python exporter.py --gen-session
STRING_SESSION=

# --- Control surface -------------------------------------------------------
# Where the userbot listens for your commands / chat ids.
#   me        -> your Saved Messages (recommended, private to you)
#   <user id> -> a specific user id allowed to command the bot (usually your own)
CONTROL_CHAT=me

# Command trigger prefix for the dot-commands (.export, .help ...).
PREFIX=.

# --- Output ----------------------------------------------------------------
# Where the feedable datasheet (.md) is written. Point this at your
# yor-assistant knowledge/feed dir to have exports auto-indexed, e.g.
#   FEED_DIR=/path/to/yor-assistant/knowledge/feed
# Default writes to a local ./feed folder.
FEED_DIR=./feed

# Where the structured JSONL export is written.
EXPORT_DIR=./exports

# Default max messages per export (0 = no limit, grab the whole history).
DEFAULT_LIMIT=0

# Send the generated files back to the control chat when done (true/false).
SEND_FILES_BACK=true
