# --- Telegram user account (get from https://my.telegram.org > API development) ---
# You can leave these blank and the userbot will prompt for them in the
# terminal at startup, along with your phone number and the OTP code.
API_ID=
API_HASH=

# Optional: pre-fill the phone number so login only asks for the OTP.
PHONE=

# Session name (a .session file is created next to the script). Keep it private.
SESSION_NAME=yor_exporter

# Optional: log in with a StringSession instead of a file session.
# Generate once with:  python exporter.py --gen-session
STRING_SESSION=

# --- Access control --------------------------------------------------------
# Extra user ids allowed to command the bot (comma/space separated). The
# account owner is ALWAYS allowed. Leave blank to allow only yourself.
ALLOWED_USERS=

# Command prefix. The workflow uses slash commands (/addids, /export ...).
PREFIX=/

# --- Pairing / filtering (mirror the from_telegram.py flags) ---------------
# Girls set is stored here and managed with /addids /rmids /ids /clearids.
GIRLS_FILE=./girls.json

# Messages to pull from a chat before pairing (0 = whole history).
FETCH_LIMIT=0

# Max prompt->response pairs emitted per export.
PAIR_LIMIT=500

# Drop a message (prompt or response) shorter than this many words.
MIN_WORDS=3

# Drop a message longer than this many characters.
MAX_CHARS=300

# When there is no reply-link, pair a girl's message with the most recent
# different-author message within this many seconds.
PAIR_WINDOW=600

# Drop messages that contain links.
DROP_LINK_MSGS=true

# Randomly sample when more pairs than PAIR_LIMIT are found (true/false).
SAMPLE=true

# Output schema: "messages" (OpenAI chat, girl = assistant turn) or
# "prompt_response" ({"prompt": ..., "response": ...}).
OUTPUT_FORMAT=messages

# Extension of the file sent back to the chat (content is JSONL regardless).
OUTPUT_EXT=txt

# Optional system prompt added to each "messages" record.
SYSTEM_PROMPT=

# Where the training .jsonl is written (and uploaded back to the chat).
EXPORT_DIR=./exports
